{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "strict": false,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "allowArbitraryExtensions": true,
    "types": ["node", "@cloudflare/workers-types"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": ["src/**/*"]
}